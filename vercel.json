{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://replace-me-backend-domain.example/api/:path*" },

    { "source": "/s/:streamer_id", "destination": "/admin" },
    { "source": "/s/:streamer_id/", "destination": "/admin" },
    { "source": "/s/:streamer_id/widget", "destination": "/widget" },
    { "source": "/s/:streamer_id/widgetyt", "destination": "/widgetyt" },
    { "source": "/s/:streamer_id/stats", "destination": "/stats" },
    { "source": "/s/:streamer_id/goal", "destination": "/goal" },

    { "source": "/", "destination": "/admin" },
    { "source": "/admin", "destination": "/admin" },
    { "source": "/widget", "destination": "/widget" },
    { "source": "/widgetyt", "destination": "/widgetyt" },
    { "source": "/stats", "destination": "/stats" },
    { "source": "/goal", "destination": "/goal" }
  ]
}
