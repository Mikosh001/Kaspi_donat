{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://replace-me-backend-domain.example/api/:path*" },

    { "source": "/s/:streamer_id", "destination": "/web/admin.html" },
    { "source": "/s/:streamer_id/", "destination": "/web/admin.html" },
    { "source": "/s/:streamer_id/widget", "destination": "/web/widget.html" },
    { "source": "/s/:streamer_id/widgetyt", "destination": "/web/widgetyt.html" },
    { "source": "/s/:streamer_id/stats", "destination": "/web/stats.html" },
    { "source": "/s/:streamer_id/goal", "destination": "/web/goal.html" },

    { "source": "/", "destination": "/web/admin.html" },
    { "source": "/admin", "destination": "/web/admin.html" },
    { "source": "/widget", "destination": "/web/widget.html" },
    { "source": "/widgetyt", "destination": "/web/widgetyt.html" },
    { "source": "/stats", "destination": "/web/stats.html" },
    { "source": "/goal", "destination": "/web/goal.html" },

    { "source": "/:asset", "destination": "/web/:asset" }
  ]
}
