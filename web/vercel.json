{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/admin.html" },
    { "source": "/connect", "destination": "/connect.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/widget", "destination": "/widget.html" },
    { "source": "/widgetyt", "destination": "/widgetyt.html" },
    { "source": "/stats", "destination": "/stats.html" },
    { "source": "/goal", "destination": "/goal.html" },

    { "source": "/s/:streamerId", "destination": "/admin.html" },
    { "source": "/s/:streamerId/", "destination": "/admin.html" },
    { "source": "/s/:streamerId/widget", "destination": "/widget.html" },
    { "source": "/s/:streamerId/widgetyt", "destination": "/widgetyt.html" },
    { "source": "/s/:streamerId/stats", "destination": "/stats.html" },
    { "source": "/s/:streamerId/goal", "destination": "/goal.html" },
    { "source": "/s/:streamerId/connect", "destination": "/connect.html" },
    { "source": "/s/:streamerId/:path*", "destination": "/:path*" }
  ]
}
