rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function streamerRef(streamerId) {
      return /databases/$(database)/documents/streamers/$(streamerId);
    }

    function streamerExists(streamerId) {
      return exists(streamerRef(streamerId));
    }

    function streamerOwnerUid(streamerId) {
      return get(streamerRef(streamerId)).data.owner_uid;
    }

    function isStreamerOwner(streamerId) {
      return isSignedIn() && streamerExists(streamerId) && streamerOwnerUid(streamerId) == request.auth.uid;
    }

    function canCreateOwnedStreamer(streamerId) {
      return isSignedIn()
        && request.resource.data.streamer_id == streamerId
        && request.resource.data.owner_uid == request.auth.uid;
    }

    match /streamers/{streamerId} {
      allow read: if true;
      allow create: if canCreateOwnedStreamer(streamerId);
      allow update, delete: if isStreamerOwner(streamerId);

      match /settings/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }

      match /analytics/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }

      match /donations/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }

      match /devices/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }

      match /donor_stats/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }

      match /leaderboards/{docId} {
        allow read: if true;
        allow write: if isStreamerOwner(streamerId);
      }
    }
  }
}
